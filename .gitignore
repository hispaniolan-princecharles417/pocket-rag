# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# lock file — install with: npm install --legacy-peer-deps
package-lock.json

# uploaded PDFs (runtime files, not source code)
/uploads/*
!uploads/.gitkeep

# debug logs
log.txt

# local debug output (set LOCAL_DEBUGGING=true in lib/settings.ts)
_local_debug/*
!_local_debug/.gitkeep
